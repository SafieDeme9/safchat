# Telegram Bot Token (required)
# Create a bot with @BotFather on Telegram and paste your token here
TELEGRAM_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Ollama host (change to http://ollama:11434 when using Docker)
# For local testing, use http://localhost:11434
OLLAMA_HOST=http://localhost:11434

# AI Model (ultra-lightweight for Raspberry Pi 4 - 0.5B params, ~400MB)
MODEL_NAME=qwen2.5:0.5b

# Debug mode - set to true during testing
DEBUG=true

# Environment (development or production)
ENVIRONMENT=development